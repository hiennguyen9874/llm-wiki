filters:
  and:
    - 'file.inFolder("raw/inbox")'
    - 'file.ext == "md"'

properties:
  file.name:
    displayName: Source
  file.folder:
    displayName: Folder
  file.mtime:
    displayName: Modified

views:
  - type: table
    name: "Inbox"
    order:
      - file.name
      - file.folder
      - file.mtime

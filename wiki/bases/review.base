filters:
  or:
    - status == "draft"
    - status == "needs_update"
    - status == "open"
    - review_status == "needs_review"
    - claim_status == "stale"
    - claim_status == "disputed"
    - page_type == "review_item"
formulas:
  page_age_days: (today() - date(last_updated)).days
properties:
  status:
    displayName: Status
  review_status:
    displayName: Review
  claim_status:
    displayName: Claim Status
  action_type:
    displayName: Action
  priority:
    displayName: Priority
  confidence_score:
    displayName: Confidence
  next_review:
    displayName: Next Review
  formula.page_age_days:
    displayName: Age (days)
views:
  - type: table
    name: Needs Review
    order:
      - file.name
      - status
      - review_status
      - claim_status
      - action_type
      - priority
      - confidence_score
      - next_review
      - formula.page_age_days

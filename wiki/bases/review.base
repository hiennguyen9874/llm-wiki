filters:
  or:
    - 'status == "draft"'
    - 'status == "needs_update"'
    - 'review_status == "needs_review"'
    - 'claim_status == "stale"'
    - 'claim_status == "disputed"'

formulas:
  page_age_days: '(today() - date(last_updated)).days'

properties:
  status:
    displayName: Status
  review_status:
    displayName: Review
  claim_status:
    displayName: Claim Status
  confidence_score:
    displayName: Confidence
  next_review:
    displayName: Next Review
  formula.page_age_days:
    displayName: Age (days)

views:
  - type: table
    name: "Needs Review"
    order:
      - file.name
      - status
      - review_status
      - claim_status
      - confidence_score
      - next_review
      - formula.page_age_days
